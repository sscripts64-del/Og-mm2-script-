-- 🔑 KEY CONFIG

local CorrectKey = "OG"

-- 💾 FUNCIÓN PARA GUARDAR LA KEY CON TIMESTAMP

local function saveKeyData()

    local keyData = {

        key = CorrectKey,

        timestamp = os.time() -- Guarda el tiempo actual en segundos

    }

    local jsonData = HttpService:JSONEncode(keyData)

    writefile("GODHub_KeyData.json", jsonData) -- Guarda en un archivo JSON

end

-- 🔍 FUNCIÓN PARA VERIFICAR SI LA KEY SIGUE VÁLIDA (24 HORAS)

local function isKeyValid()

    if not isfile("GODHub_KeyData.json") then

        return false -- No hay archivo guardado

    end

    

    local success, jsonData = pcall(function()

        return readfile("GODHub_KeyData.json")

    end)

    

    if not success then

        return false

    end

    

    local success, keyData = pcall(function()

        return HttpService:JSONDecode(jsonData)

    end)

    

    if not success or not keyData or not keyData.timestamp then

        return false

    end

    

    local currentTime = os.time()

    local timeDiff = currentTime - keyData.timestamp -- Diferencia en segundos

    local hoursPassed = timeDiff / 3600 -- Convertir a horas

    

    -- Verificar si han pasado menos de 24 horas

    return hoursPassed < 24

end

-- DRAG FUNCTION

local function Drag(gui)

    local dragging, dragStart, startPos

    gui.Active = true

    gui.InputBegan:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then

            dragging = true

            dragStart = input.Position

            startPos = gui.Position

        end

    end)

    UIS.InputChanged:Connect(function(input)

        if dragging then

            local delta = input.Position - dragStart

            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,

                                     startPos.Y.Scale, startPos.Y.Offset + delta.Y)

        end

    end)

    UIS.InputEnded:Connect(function()

        dragging = false

    end)

end

